# Application
APP_NAME=RecipeRecommend
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Redis Cache TTL (seconds)
REDIS_TTL_USER_PROFILE=3600
REDIS_TTL_RECOMMEND=1800
REDIS_TTL_POPULAR=600
REDIS_TTL_TOPK=300

# FAISS
FAISS_INDEX_PATH=models/faiss_hnsw.index
FAISS_DIMENSION=64
FAISS_M=32
FAISS_EF_CONSTRUCTION=200
FAISS_EF_SEARCH=64

# Embedding
EMBEDDING_DIM=64
EMBEDDING_MODEL_PATH=models/embeddings.npz

# Ranking
RANK_MODEL_PATH=models/xgb_rank_model.json
RANK_TOP_K=100

# Data
AUTH_DB_PATH=data/auth_users.db

# Spark
# Local mode: local[*]
# Standalone cluster example: spark://192.168.88.161:7077
SPARK_MASTER_URL=spark://192.168.88.161:7077
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g
SPARK_EXECUTOR_CORES=1
SPARK_EXECUTOR_INSTANCES=3
SPARK_SQL_SHUFFLE_PARTITIONS=12
SPARK_DEFAULT_PARALLELISM=12
SPARK_UI_SHOW_CONSOLE_PROGRESS=false

# Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=node1:9092
KAFKA_FEEDBACK_TOPIC=recipe_feedback
KAFKA_REALTIME_RECOMMEND_TOPIC=recipe_realtime_recommend
KAFKA_CLIENT_ID=reciperec-api
KAFKA_CONSUMER_GROUP=reciperec-feedback-consumer
KAFKA_REQUEST_TIMEOUT_MS=3000

# MinIO artifact storage
# Windows local MinIO example: localhost:9000
# VM uploading to Windows MinIO example: 192.168.88.1:9000 or your Windows host IP:9000
MINIO_ENABLED=true
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=reciperec
MINIO_ARTIFACT_PREFIX=offline/latest
MINIO_CONNECT_TIMEOUT_SECONDS=3
MINIO_READ_TIMEOUT_SECONDS=10

# DeepSeek
DEEPSEEK_MODEL=deepseek-v4-flash

# Recommendation
RECALL_TOP_K=200
FINAL_TOP_K=20
POPULAR_FALLBACK_COUNT=50
