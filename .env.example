# Application
APP_NAME=MovieLensRecommend
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Redis Cache TTL (seconds)
REDIS_TTL_USER_PROFILE=3600
REDIS_TTL_RECOMMEND=1800
REDIS_TTL_POPULAR=600
REDIS_TTL_TOPK=300

# FAISS
FAISS_INDEX_PATH=models/faiss_hnsw.index
FAISS_DIMENSION=64
FAISS_M=32
FAISS_EF_CONSTRUCTION=200
FAISS_EF_SEARCH=64

# Embedding
EMBEDDING_DIM=64
EMBEDDING_MODEL_PATH=models/embeddings.npz

# Ranking
RANK_MODEL_PATH=models/xgb_rank_model.json
RANK_TOP_K=100

# Data
MOVIELENS_DATA_DIR=data/ml-latest-small
MOVIELENS_URL=https://files.grouplens.org/datasets/movielens/ml-latest-small.zip

# Recommendation
RECALL_TOP_K=200
FINAL_TOP_K=20
POPULAR_FALLBACK_COUNT=50
